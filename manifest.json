{
  "manifest_version": 3,
  "name": "GM Baselinker improver",
  "description": "Ulepszenie Baselinkera",
  "version": "1.1",
  "icons": {
    "128": "128.png"
  },
  "icons": {
    "16": "images/logo16.png",
    "48": "images/logo48.png",
    "128": "images/logo128.png"
  },
  "action": {

  },
  "content_scripts": [
    {
      "matches": [
        "https://panel.baselinker.com/orders.php",
        "https://panel.baselinker.com/orders_returns.php" ],
      "js": ["index.js"],
      "css": ["product_amount_style.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "unlimitedStorage",
    "notifications",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "*://panel.baselinker.com/*"
  ]
}